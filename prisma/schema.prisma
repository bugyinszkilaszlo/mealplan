// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//Enums
enum MealGroup {
  BREAKFAST
  BRUNCH
  LUNCH
  SNACK
  DINNER
}

enum MealType {
  STARTER
  MAIN
  DESSERT
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Unit {
  G
  KG
  L
  ML
  PIECE
  PINCH
  TBSP
  TSP
}

// Better-Auth Models
model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime
  updatedAt     DateTime

  sessions      Session[]
  accounts      Account[]
  recipes       Recipe[]
}

model Session {
  id        String   @id
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime
  updatedAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                       String   @id
  userId                   String
  accountId                String
  providerId               String
  accessToken              String?
  refreshToken             String?
  accessTokenExpiresAt     DateTime?
  refreshTokenExpiresAt    DateTime?
  scope                    String?
  idToken                  String?
  password                 String?
  createdAt                DateTime
  updatedAt                DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime
  updatedAt  DateTime
}

//Other Models
model Recipe {
  id           String        @id @default(cuid())
  name         String
  imageUrl     String?
  prepTime     Int           
  cookTime     Int           
  portions     Int
  createdAt    DateTime      @default(now())

  mealGroup    MealGroup
  mealType     MealType
  difficulty   Difficulty

  userId       String
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  labels       Label[]
  ingredients  Ingredient[]
  instructions Instruction[]
  tips         Tip[]

  @@index([mealType])
  @@index([difficulty])
  @@index([mealGroup])
}

model Label {
  id      String   @id @default(cuid())
  name    String   @unique
  recipes Recipe[]
}

model Ingredient {
  id        String  @id @default(cuid())
  name      String
  amount    Float
  unit      Unit

  recipeId  String
  recipe    Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([name])
  @@index([recipeId])
}

model Instruction {
  id          String  @id @default(cuid())
  stepName    String
  description String  @db.Text
  order       Int

  recipeId    String
  recipe      Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
  @@index([order])
}


model Tip {
  id          String  @id @default(cuid())
  name        String
  description String  @db.Text

  recipeId    String
  recipe      Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([recipeId])
}
